@inject ApiClient Api
@inject ToastService Toasts

@if (IsOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(IsEdit ? "Editar item" : "Novo item")</h5>
                    <button type="button" class="btn-close" @onclick="OnCancel" aria-label="Fechar"></button>
                </div>
                <EditForm Model="_form" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    <div class="modal-body">

                        @if (!IsEdit)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Código <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_form.Code" placeholder="ex: XBACON" />
                                <ValidationMessage For="() => _form.Code" class="text-danger small" />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nome <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_form.Name" placeholder="ex: X-Bacon" />
                            <ValidationMessage For="() => _form.Name" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Preço (R$) <span class="text-danger">*</span></label>
                            <InputNumber class="form-control" @bind-Value="_form.Price" />
                            <ValidationMessage For="() => _form.Price" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Categoria <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="_form.Category">
                                <option value="@ProductCategory.Sandwich">Sanduíche</option>
                                <option value="@ProductCategory.Fries">Acompanhamento</option>
                                <option value="@ProductCategory.Drink">Bebida</option>
                            </InputSelect>
                        </div>

                        @if (IsEdit)
                        {
                            <div class="mb-3 form-check">
                                <InputCheckbox class="form-check-input" id="isActiveCheck"
                                               @bind-Value="_form.IsActive" />
                                <label class="form-check-label" for="isActiveCheck">Ativo</label>
                            </div>
                        }

                        @if (_error is not null)
                        {
                            <div class="alert alert-danger py-2 small">@_error</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="OnCancel">Cancelar</button>
                        <button type="submit" class="btn btn-gh-primary" disabled="@_saving">
                            @(_saving ? "Salvando..." : "Salvar")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public MenuItemModel? EditItem { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    FormModel _form = new();
    bool _saving;
    string? _error;

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            _error = null;
            _saving = false;
            if (IsEdit && EditItem is not null)
            {
                _form = new FormModel
                {
                    Code     = EditItem.Code,
                    Name     = EditItem.Name,
                    Price    = EditItem.Price,
                    Category = EditItem.Category,
                    IsActive = EditItem.IsActive
                };
            }
            else
            {
                _form = new FormModel();
            }
        }
    }

    async Task HandleSubmit()
    {
        _saving = true;
        _error = null;

        if (IsEdit && EditItem is not null)
        {
            var req = new UpdateMenuItemRequest(_form.Name, _form.Price, _form.Category, _form.IsActive);
            var (_, err) = await Api.UpdateMenuItemAsync(EditItem.Id, req);
            if (err is not null) { _error = err; _saving = false; return; }
            Toasts.Show("Item atualizado com sucesso.", ToastType.Success);
        }
        else
        {
            var req = new CreateMenuItemRequest(_form.Code, _form.Name, _form.Price, _form.Category);
            var (_, err) = await Api.CreateMenuItemAsync(req);
            if (err is not null) { _error = err; _saving = false; return; }
            Toasts.Show("Item criado com sucesso.", ToastType.Success);
        }

        _saving = false;
        await OnSaved.InvokeAsync();
    }

    class FormModel
    {
        [Required(ErrorMessage = "Código é obrigatório.")]
        [MaxLength(50)]
        public string Code { get; set; } = "";

        [Required(ErrorMessage = "Nome é obrigatório.")]
        [MaxLength(200)]
        public string Name { get; set; } = "";

        [Range(0.01, 9999.99, ErrorMessage = "Preço deve ser maior que zero.")]
        public decimal Price { get; set; }

        public ProductCategory Category { get; set; } = ProductCategory.Sandwich;

        public bool IsActive { get; set; } = true;
    }
}
