@page "/pedidos"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Pedidos - Good Hamburger</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Pedidos</h1>
        <a href="/pedido/novo" class="btn btn-success">Novo pedido</a>
    </div>

    @if (_loading)
    {
        <div class="spinner-border" role="status"></div>
    }
    else if (_orders.Count == 0)
    {
        <div class="alert alert-info">Nenhum pedido encontrado.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Pedido</th>
                    <th>Data</th>
                    <th>Itens</th>
                    <th>Total</th>
                    <th>Acoes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in _orders)
                {
                    <tr>
                        <td><code>@order.Id.ToString()[..8]</code></td>
                        <td>@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@string.Join(", ", order.Items.Select(i => i.MenuItemName))</td>
                        <td>R$ @order.Total.ToString("0.00")</td>
                        <td>
                            <a href="/pedidos/@order.Id" class="btn btn-sm btn-primary me-1">Ver</a>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteOrder(order.Id)">Excluir</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (_totalCount > _pageSize)
        {
            <nav>
                <ul class="pagination">
                    <li class="page-item @(_page <= 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => ChangePage(_page - 1)">Anterior</button>
                    </li>
                    <li class="page-item @(_page * _pageSize >= _totalCount ? "disabled" : "")">
                        <button class="page-link" @onclick="() => ChangePage(_page + 1)">Proxima</button>
                    </li>
                </ul>
            </nav>
        }
    }

    @if (_errorMessage is not null)
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }
</div>

@code {
    private List<OrderModel> _orders = [];
    private bool _loading = true;
    private string? _errorMessage;
    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        _loading = true;
        var result = await Api.GetOrdersAsync(_page, _pageSize);
        _orders = result.Items;
        _totalCount = result.TotalCount;
        _loading = false;
    }

    private async Task ChangePage(int page)
    {
        _page = page;
        await LoadOrders();
    }

    private async Task DeleteOrder(Guid id)
    {
        var error = await Api.DeleteOrderAsync(id);
        if (error is null)
            await LoadOrders();
        else
            _errorMessage = error;
    }
}
