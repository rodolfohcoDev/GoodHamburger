@page "/pedidos"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav
@inject ToastService Toasts

<PageTitle>Pedidos — Good Hamburger</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>📋 Pedidos</h3>
    <a href="/pedido/novo" class="btn btn-gh-primary"><i class="bi bi-plus-lg me-1"></i>Novo pedido</a>
</div>

@if (_loading)
{
    <LoadingSpinner Message="Carregando pedidos..." />
}
else if (_orders.Count == 0)
{
    <EmptyState Icon="📭" Title="Nenhum pedido encontrado"
                Message="Clique em Novo pedido para começar."
                ActionLabel="Novo pedido"
                OnAction='() => Nav.NavigateTo("/pedido/novo")' />
}
else
{
    <div class="card-gh p-0 overflow-hidden">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Pedido</th>
                    <th>Data</th>
                    <th>Itens</th>
                    <th>Total</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in _orders)
                {
                    <tr>
                        <td><code class="text-muted">@order.Id.ToString()[..8]…</code></td>
                        <td>@order.CreatedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")</td>
                        <td>
                            @foreach (var item in order.Items)
                            {
                                <span class="chip me-1">@CategoryEmoji(item.Category) @item.MenuItemName</span>
                            }
                        </td>
                        <td><PriceDisplay Value="@order.Total" /></td>
                        <td class="text-end">
                            <a href="/pedidos/@order.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => ConfirmDelete(order.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_totalCount > _pageSize)
    {
        <nav class="mt-3">
            <ul class="pagination">
                <li class="page-item @(_page <= 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(_page - 1)">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </button>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">@_page / @TotalPages</span>
                </li>
                <li class="page-item @(_page >= TotalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(_page + 1)">
                        Próxima <i class="bi bi-chevron-right"></i>
                    </button>
                </li>
            </ul>
        </nav>
    }
}

@if (_errorMessage is not null)
{
    <div class="alert alert-danger mt-3">@_errorMessage</div>
}

<ConfirmDialog IsOpen="_confirmOpen"
               Title="Excluir pedido"
               Message="Tem certeza que deseja excluir este pedido? Essa ação não pode ser desfeita."
               ConfirmLabel="Excluir"
               OnConfirm="ExecuteDelete"
               OnCancel="() => _confirmOpen = false" />

@code {
    List<OrderModel> _orders = [];
    bool _loading = true;
    string? _errorMessage;
    int _page = 1;
    const int _pageSize = 20;
    int _totalCount;
    bool _confirmOpen;
    Guid _pendingDeleteId;

    int TotalPages => (int)Math.Ceiling((double)_totalCount / _pageSize);

    protected override async Task OnInitializedAsync() => await LoadOrders();

    async Task LoadOrders()
    {
        _loading = true;
        _errorMessage = null;
        var result = await Api.GetOrdersAsync(_page, _pageSize);
        _orders = result.Items;
        _totalCount = result.TotalCount;
        _loading = false;
    }

    async Task ChangePage(int page)
    {
        _page = page;
        await LoadOrders();
    }

    void ConfirmDelete(Guid id) { _pendingDeleteId = id; _confirmOpen = true; }

    async Task ExecuteDelete()
    {
        _confirmOpen = false;
        var error = await Api.DeleteOrderAsync(_pendingDeleteId);
        if (error is null)
        {
            Toasts.Show("Pedido excluído.", ToastType.Success);
            await LoadOrders();
        }
        else
            _errorMessage = error;
    }

    static string CategoryEmoji(ProductCategory cat) => cat switch
    {
        ProductCategory.Sandwich => "🥪",
        ProductCategory.Fries    => "🍟",
        ProductCategory.Drink    => "🥤",
        _ => "•"
    };
}

