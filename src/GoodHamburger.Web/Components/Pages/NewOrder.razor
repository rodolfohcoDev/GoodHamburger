@page "/pedido/novo"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav
@inject ToastService Toasts

<PageTitle>Novo pedido — Good Hamburger</PageTitle>

<div class="mb-3">
    <h3>🧾 Novo pedido</h3>
    <p class="text-muted mb-0">Selecione os itens para montar seu pedido.</p>
</div>

@if (_loading)
{
    <LoadingSpinner Message="Carregando cardápio..." />
}
else
{
    <div class="row g-4">
        <!-- Seleção -->
        <div class="col-lg-8">

            <!-- Sanduíches -->
            <div class="card-gh mb-3">
                <h6 class="fw-bold mb-3">🥪 Escolha seu sanduíche <span class="text-danger">*</span></h6>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var item in _sandwiches)
                    {
                        <div class="card-gh selectable @(_selectedSandwich?.Id == item.Id ? "selected" : "")"
                             style="min-width:160px; cursor:pointer"
                             @onclick="() => SelectSandwich(item)" role="button" tabindex="0"
                             @onkeydown='e => { if (e.Key == "Enter" || e.Key == " ") SelectSandwich(item); }'>
                            <strong>@item.Name</strong>
                            <div class="text-danger mt-1"><PriceDisplay Value="@item.Price" /></div>
                        </div>
                    }
                </div>
            </div>

            <!-- Acompanhamento -->
            <div class="card-gh mb-3">
                <h6 class="fw-bold mb-3">🍟 Quer uma batata?</h6>
                <div class="d-flex flex-wrap gap-3">
                    <div class="card-gh selectable @(_selectedFries == null ? "selected" : "")"
                         style="min-width:120px; cursor:pointer"
                         @onclick="() => SelectFries(null)" role="button" tabindex="0">
                        <strong>Nenhuma</strong>
                    </div>
                    @foreach (var item in _fries)
                    {
                        <div class="card-gh selectable @(_selectedFries?.Id == item.Id ? "selected" : "")"
                             style="min-width:160px; cursor:pointer"
                             @onclick="() => SelectFries(item)" role="button" tabindex="0"
                             @onkeydown='e => { if (e.Key == "Enter" || e.Key == " ") SelectFries(item); }'>
                            <strong>@item.Name</strong>
                            <div class="text-danger mt-1"><PriceDisplay Value="@item.Price" /></div>
                        </div>
                    }
                </div>
            </div>

            <!-- Bebida -->
            <div class="card-gh mb-3">
                <h6 class="fw-bold mb-3">🥤 E pra beber?</h6>
                <div class="d-flex flex-wrap gap-3">
                    <div class="card-gh selectable @(_selectedDrink == null ? "selected" : "")"
                         style="min-width:120px; cursor:pointer"
                         @onclick="() => SelectDrink(null)" role="button" tabindex="0">
                        <strong>Nenhuma</strong>
                    </div>
                    @foreach (var item in _drinks)
                    {
                        <div class="card-gh selectable @(_selectedDrink?.Id == item.Id ? "selected" : "")"
                             style="min-width:160px; cursor:pointer"
                             @onclick="() => SelectDrink(item)" role="button" tabindex="0"
                             @onkeydown='e => { if (e.Key == "Enter" || e.Key == " ") SelectDrink(item); }'>
                            <strong>@item.Name</strong>
                            <div class="text-danger mt-1"><PriceDisplay Value="@item.Price" /></div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Resumo -->
        <div class="col-lg-4">
            <div class="card-gh sticky-top" style="top:1rem">
                <h6 class="fw-bold mb-3">Resumo do pedido</h6>
                @if (!SelectedItems.Any())
                {
                    <p class="text-muted small">Nenhum item selecionado.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-3">
                        @foreach (var item in SelectedItems)
                        {
                            <li class="d-flex justify-content-between py-1 border-bottom">
                                <span>@item.Name</span>
                                <PriceDisplay Value="@item.Price" />
                            </li>
                        }
                    </ul>
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span>Subtotal</span><PriceDisplay Value="@Subtotal" />
                    </div>
                    @if (DiscountPercent > 0)
                    {
                        <div class="d-flex justify-content-between small text-success mb-1">
                            <span>Desconto (@DiscountPercent%)</span>
                            <span>- <PriceDisplay Value="@DiscountAmount" /></span>
                        </div>
                        <div class="chip mb-2">🎉 @DiscountLabel</div>
                    }
                    @if (_simulationLoading)
                    {
                        <div class="text-muted small mb-1"><i class="bi bi-hourglass-split me-1"></i>Calculando desconto...</div>
                    }                    <div class="d-flex justify-content-between fw-bold fs-6 pt-2 border-top">
                        <span>Total</span><PriceDisplay Value="@Total" />
                    </div>
                }

                @if (_errorMessage is not null)
                {
                    <div class="alert alert-danger mt-3 small py-2">@_errorMessage</div>
                }

                <button class="btn btn-gh-primary w-100 mt-3"
                        disabled="@(!SelectedItems.Any() || _submitting)"
                        @onclick="SubmitOrder">
                    @(_submitting ? "Enviando..." : "Fazer pedido")
                </button>
            </div>
        </div>
    </div>
}

@code {
    List<MenuItemModel> _sandwiches = [];
    List<MenuItemModel> _fries = [];
    List<MenuItemModel> _drinks = [];
    MenuItemModel? _selectedSandwich;
    MenuItemModel? _selectedFries;
    MenuItemModel? _selectedDrink;
    bool _loading = true;
    bool _submitting;
    bool _simulationLoading;
    string? _errorMessage;
    SimulationResult? _simulation;
    CancellationTokenSource _simCts = new();

    protected override async Task OnInitializedAsync()
    {
        var menu = await Api.GetMenuAsync();
        _sandwiches = menu.Where(m => m.Category == ProductCategory.Sandwich).ToList();
        _fries      = menu.Where(m => m.Category == ProductCategory.Fries).ToList();
        _drinks     = menu.Where(m => m.Category == ProductCategory.Drink).ToList();
        _loading = false;
    }

    void SelectSandwich(MenuItemModel item)
    {
        _selectedSandwich = _selectedSandwich?.Id == item.Id ? null : item;
        _ = TriggerSimulationAsync();
    }

    void SelectFries(MenuItemModel? item)
    {
        _selectedFries = item;
        _ = TriggerSimulationAsync();
    }

    void SelectDrink(MenuItemModel? item)
    {
        _selectedDrink = item;
        _ = TriggerSimulationAsync();
    }

    async Task TriggerSimulationAsync()
    {
        await _simCts.CancelAsync();
        _simCts = new CancellationTokenSource();
        var token = _simCts.Token;

        var ids = SelectedItems.Select(i => i.Id).ToList();
        if (!ids.Any())
        {
            _simulation = null;
            StateHasChanged();
            return;
        }

        _simulationLoading = true;
        StateHasChanged();

        try
        {
            await Task.Delay(300, token);
            var (result, _) = await Api.SimulateDiscountAsync(ids);
            if (!token.IsCancellationRequested)
            {
                _simulation = result;
                _simulationLoading = false;
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        catch
        {
            _simulationLoading = false;
            StateHasChanged();
        }
    }

    IEnumerable<MenuItemModel> SelectedItems =>
        new[] { _selectedSandwich, _selectedFries, _selectedDrink }.OfType<MenuItemModel>();

    decimal Subtotal => SelectedItems.Sum(i => i.Price);

    decimal DiscountPercent => _simulation?.AppliedPercent ?? 0m;

    string DiscountLabel => _simulation?.AppliedRuleName is { } name ? $"{name} — {DiscountPercent}% de desconto" : string.Empty;

    decimal DiscountAmount => _simulation?.DiscountAmount ?? Math.Round(Subtotal * (DiscountPercent / 100), 2, MidpointRounding.AwayFromZero);
    decimal Total => _simulation?.Total ?? (Subtotal - DiscountAmount);

    async Task SubmitOrder()
    {
        _submitting = true;
        _errorMessage = null;
        var ids = SelectedItems.Select(i => i.Id).ToList();
        var (order, error) = await Api.CreateOrderAsync(ids);
        _submitting = false;

        if (order is not null)
        {
            Toasts.Show("Pedido criado com sucesso!", ToastType.Success);
            Nav.NavigateTo($"/pedidos/{order.Id}");
        }
        else
            _errorMessage = error;
    }
}

