@page "/pedido/novo"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Monte seu pedido - Good Hamburger</PageTitle>

<div class="container-fluid">
    <h1 class="mb-4">Monte seu pedido</h1>

    @if (_loading)
    {
        <div class="spinner-border" role="status"><span class="visually-hidden">Carregando...</span></div>
    }
    else
    {
        <div class="row">
            <!-- Seleção -->
            <div class="col-md-8">

                <!-- Sanduíches -->
                <div class="card mb-3">
                    <div class="card-header bg-warning text-dark fw-bold">Escolha seu sanduiche</div>
                    <div class="card-body d-flex flex-wrap gap-3">
                        @foreach (var item in _sandwiches)
                        {
                            <div class="form-check card p-3" style="min-width:150px; cursor:pointer"
                                 @onclick="() => SelectSandwich(item)">
                                <input class="form-check-input" type="radio" name="sandwich"
                                       checked="@(_selectedSandwich?.Id == item.Id)" />
                                <label class="form-check-label ms-2">
                                    <strong>@item.Name</strong><br />
                                    <span class="text-success">R$ @item.Price.ToString("0.00")</span>
                                </label>
                            </div>
                        }
                    </div>
                </div>

                <!-- Batata -->
                <div class="card mb-3">
                    <div class="card-header bg-warning text-dark fw-bold">Quer uma batata?</div>
                    <div class="card-body d-flex flex-wrap gap-3">
                        <div class="form-check card p-3" style="min-width:150px; cursor:pointer"
                             @onclick="() => _selectedFries = null">
                            <input class="form-check-input" type="radio" name="fries"
                                   checked="@(_selectedFries == null)" />
                            <label class="form-check-label ms-2"><strong>Nenhuma</strong></label>
                        </div>
                        @foreach (var item in _fries)
                        {
                            <div class="form-check card p-3" style="min-width:150px; cursor:pointer"
                                 @onclick="() => _selectedFries = item">
                                <input class="form-check-input" type="radio" name="fries"
                                       checked="@(_selectedFries?.Id == item.Id)" />
                                <label class="form-check-label ms-2">
                                    <strong>@item.Name</strong><br />
                                    <span class="text-success">R$ @item.Price.ToString("0.00")</span>
                                </label>
                            </div>
                        }
                    </div>
                </div>

                <!-- Bebida -->
                <div class="card mb-3">
                    <div class="card-header bg-warning text-dark fw-bold">E pra beber?</div>
                    <div class="card-body d-flex flex-wrap gap-3">
                        <div class="form-check card p-3" style="min-width:150px; cursor:pointer"
                             @onclick="() => _selectedDrink = null">
                            <input class="form-check-input" type="radio" name="drink"
                                   checked="@(_selectedDrink == null)" />
                            <label class="form-check-label ms-2"><strong>Nenhuma</strong></label>
                        </div>
                        @foreach (var item in _drinks)
                        {
                            <div class="form-check card p-3" style="min-width:150px; cursor:pointer"
                                 @onclick="() => _selectedDrink = item">
                                <input class="form-check-input" type="radio" name="drink"
                                       checked="@(_selectedDrink?.Id == item.Id)" />
                                <label class="form-check-label ms-2">
                                    <strong>@item.Name</strong><br />
                                    <span class="text-success">R$ @item.Price.ToString("0.00")</span>
                                </label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Resumo -->
            <div class="col-md-4">
                <div class="card sticky-top" style="top:1rem">
                    <div class="card-header bg-dark text-white fw-bold">Resumo do pedido</div>
                    <div class="card-body">
                        @if (!SelectedItems.Any())
                        {
                            <p class="text-muted">Nenhum item selecionado.</p>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush mb-3">
                                @foreach (var item in SelectedItems)
                                {
                                    <li class="list-group-item d-flex justify-content-between">
                                        <span>@item.Name</span>
                                        <span>R$ @item.Price.ToString("0.00")</span>
                                    </li>
                                }
                            </ul>
                            <div class="mb-1 d-flex justify-content-between">
                                <span>Subtotal</span><span>R$ @Subtotal.ToString("0.00")</span>
                            </div>
                            @if (DiscountPercent > 0)
                            {
                                <div class="mb-1 text-success d-flex justify-content-between">
                                    <span>Desconto (@DiscountPercent%)</span>
                                    <span>- R$ @DiscountAmount.ToString("0.00")</span>
                                </div>
                                <div class="alert alert-success py-1 px-2 small">
                                    @DiscountMessage
                                </div>
                            }
                            <div class="fw-bold fs-5 d-flex justify-content-between border-top pt-2">
                                <span>Total</span><span>R$ @Total.ToString("0.00")</span>
                            </div>
                        }

                        @if (_errorMessage is not null)
                        {
                            <div class="alert alert-danger mt-3">@_errorMessage</div>
                        }

                        <button class="btn btn-success w-100 mt-3" disabled="@(!SelectedItems.Any() || _submitting)"
                                @onclick="SubmitOrder">
                            @(_submitting ? "Enviando..." : "Fazer pedido")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<MenuItemModel> _sandwiches = [];
    private List<MenuItemModel> _fries = [];
    private List<MenuItemModel> _drinks = [];
    private MenuItemModel? _selectedSandwich;
    private MenuItemModel? _selectedFries;
    private MenuItemModel? _selectedDrink;
    private bool _loading = true;
    private bool _submitting = false;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var menu = await Api.GetMenuAsync();
        _sandwiches = menu.Where(m => m.Category == ProductCategory.Sandwich).ToList();
        _fries = menu.Where(m => m.Category == ProductCategory.Fries).ToList();
        _drinks = menu.Where(m => m.Category == ProductCategory.Drink).ToList();
        _loading = false;
    }

    private void SelectSandwich(MenuItemModel item)
    {
        _selectedSandwich = _selectedSandwich?.Id == item.Id ? null : item;
    }

    private IEnumerable<MenuItemModel> SelectedItems =>
        new[] { _selectedSandwich, _selectedFries, _selectedDrink }.OfType<MenuItemModel>();

    private decimal Subtotal => SelectedItems.Sum(i => i.Price);

    private decimal DiscountPercent
    {
        get
        {
            bool hasSandwich = _selectedSandwich is not null;
            bool hasFries = _selectedFries is not null;
            bool hasDrink = _selectedDrink is not null;
            if (hasSandwich && hasFries && hasDrink) return 20m;
            if (hasSandwich && hasDrink) return 15m;
            if (hasSandwich && hasFries) return 10m;
            return 0m;
        }
    }

    private decimal DiscountAmount => Math.Round(Subtotal * (DiscountPercent / 100), 2, MidpointRounding.AwayFromZero);
    private decimal Total => Subtotal - DiscountAmount;

    private string DiscountMessage => DiscountPercent switch
    {
        20m => "Voce ganhou 20% de desconto no combo completo!",
        15m => "Voce ganhou 15% de desconto (sanduiche + bebida)!",
        10m => "Voce ganhou 10% de desconto (sanduiche + batata)!",
        _ => string.Empty
    };

    private async Task SubmitOrder()
    {
        _submitting = true;
        _errorMessage = null;
        var ids = SelectedItems.Select(i => i.Id).ToList();
        var (order, error) = await Api.CreateOrderAsync(ids);
        _submitting = false;

        if (order is not null)
            Nav.NavigateTo($"/pedidos/{order.Id}?success=true");
        else
            _errorMessage = error;
    }
}
