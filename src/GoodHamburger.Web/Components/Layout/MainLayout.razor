@inherits LayoutComponentBase

<div class="gh-shell">
    <aside class="gh-sidebar @(_sidebarOpen ? "open" : "")">
        <NavMenu />
    </aside>
    <main class="gh-main">
        <header class="gh-topbar">
            <button class="btn btn-sm btn-outline-secondary d-lg-none me-2"
                    @onclick="ToggleSidebar" aria-label="Menu">
                <i class="bi bi-list fs-5"></i>
            </button>
            <span class="brand">🍔 Good Hamburger</span>
            <span class="tagline d-none d-sm-inline">Sistema de pedidos</span>
        </header>
        <div class="gh-content">@Body</div>
    </main>
    <Toast />
</div>

@code {
    bool _sidebarOpen;
    void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
}

